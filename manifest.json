{
  "manifest_version": 3,
  "name": "Filra",
  "version": "1.0",
  "description": "The Claude's flowery styled logo roaming on the screen created for the Major League Hacking event. Made with love for Claude-lovers",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["character.gif"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png"
  }
}
